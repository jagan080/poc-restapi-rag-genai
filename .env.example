# Environment Configuration for RAG GenAI API

# ========================================
# LLM Provider Configuration
# ========================================
# LLM_PROVIDER: 1=HuggingFace, 2=Ollama, 3=Gemini Vertex AI
LLM_PROVIDER=3
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ========================================
# Google Cloud Configuration
# ========================================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.5-pro

# ========================================
# Ollama Configuration (if using LLM_PROVIDER=2)
# ========================================
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=deepseek-r1:7b

# ========================================
# Application Configuration
# ========================================
APP_HOST=0.0.0.0
APP_PORT=5001
APP_ENV=production
DEBUG=False
LOG_LEVEL=INFO

# ========================================
# ChromaDB Configuration
# ========================================
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=rag_docs

# ========================================
# Embedding Model Configuration
# ========================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_MODEL_DEVICE=cpu

# ========================================
# RAG Configuration
# ========================================
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.5
TEXT_CHUNK_SIZE=500
TEXT_CHUNK_OVERLAP=50

# ========================================
# API Configuration
# ========================================
API_TITLE=RAG GenAI APIx
API_VERSION=1.0.0
API_DESCRIPTION=Retrieval-Augmented Generation API with GenAI
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5001"]

# ========================================
# Database Configuration (for future use)
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/rag_genai

# ========================================
# Knowledge Base Configuration
# ========================================
KB_DATA_FOLDER=./data
KB_AUTO_RELOAD=True
